  "license": "ISC",
  "bugs": {
    "url": "https://github.com/kaipahl/defaults/issues"
  },
  "homepage": "https://github.com/kaipahl/defaults",
  "dependencies": {
    "ev-emitter": "^2.1.0",
    "expose-loader": "^1.0.3"
  },
  "devDependencies": {
    "autoprefixer": "^10.4.20",
    "cpy": "^8.1.1",
    "eslint": "^6.1.0",
    "postcss": "^8.4.49",
    "postcss-cli": "^11.0.0",
    "prettier": "^3.8.4",
    "sass": "^1.83.1",
    "stylelint": "^17.13.0",
    "stylelint-config-standard-scss": "^17.0.0",
    "vite": "^8.0.16",
